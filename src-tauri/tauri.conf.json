{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oceanside",
  "version": "0.1.0",
  "identifier": "com.oceanside.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "oceanside",
        "width": 480,
        "height": 680,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "macOS": {
      "infoPlist": "Info.plist",
      "signingIdentity": "-"
    }
  }
}
